{
  "id": "nodebb-plugin-announcement-mailer",
  "name": "Announcement Mailer",
  "description": "Send targeted bulk emails to user groups from the ACP.",
  "url": "https://forum.ieu.app",
  "library": "./library.js",
  "modules": {
    "../admin/plugins/announcement-mailer.js": "static/lib/admin.js"
  },
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "filter:admin.header.build",
      "method": "addAdminNavigation"
    },
    {
      "hook": "action:topic.post",
      "method": "onTopicPost"
    }
  ],
  "staticDirs": {
    "static": "./static"
  },
  "templates": "static/templates"
}
